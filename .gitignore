.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# OpenCode plugin dependencies and runtime data
.opencode/node_modules/
.opencode/bun.lock
.opencode/worktrees/

# Claude Code local settings
.claude/settings.local.json

# Codex config and curated assets are tracked; runtime state/cache files are local-only.
.codex/auth.json
.codex/*
!.codex/config.toml
!.codex/model-catalogs/
.codex/model-catalogs/*
!.codex/model-catalogs/cloudflare-ai-gateway.json
!.codex/rules/
.codex/rules/*
!.codex/rules/default.rules
!.codex/themes/
.codex/themes/*
!.codex/themes/orng.tmTheme

# Database tools config
.config/configstore/
.config/pgcli/*
.config/planetscale/*

# Atuin receipts
.config/atuin/atuin-receipt.json

# Zed prompt library database
.config/zed/prompts/*

# Zsh completion dump
.zcompdump*
.config/opencode/node_modules

# Pi agent runtime sessions
.pi/agent/auth.json
.pi/agent/sessions/
